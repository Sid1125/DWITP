# DWITP .gitignore

# Environment files
.env
.env.local
*.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.claude/

# OS
.DS_Store
Thumbs.db

# Terraform
*.tfstate
*.tfstate.backup
.terraform/
terraform.tfvars

# Docker
*.tar
*.tar.gz

# Logs
*.log
/var/log/

# Audit
audit.log

# SpaCy models (downloaded at build)
/usr/lib/python3.*/site-packages/en_core_web_*
!src/analysis/*.py

# Secrets (never commit)
**/secrets/
*.pem
*.key
*.cert
config/dread_cookies.txt

# Test artifacts
.htmlcov
.coverage
coverage.xml
.pytest_cache/
.pytest_tmp/
__pycache__/

# Temp & scratch files
tmp_*.py
tmp_*.json
tmp-*.py
tmp-*.json
tmp-*.txt
write_report.py
infra/*.py
infra/*.html
infra/*.json

# Microsoft Office temp files
~$*.docx
~$*.xlsx
~WRL*.tmp

