# DWITP Environment Configuration
# ============================================================================
# Copy this file to  infra/.env  and fill in the secrets, OR just run the setup
# script (scripts/setup.sh / setup.ps1) which generates infra/.env for you.
#
#   cp .env.example infra/.env      # then edit the REQUIRED values below
#
# The stack is launched from the infra/ directory, so the env file MUST live at
# infra/.env (next to docker-compose.yml). Every value here is read by Docker
# Compose at `up` time.
# ============================================================================

# ── REQUIRED ───────────────────────────────────────────────────────────────
# The stack will NOT start if any of these are empty. Use long random values.
# Generate good ones with:  openssl rand -hex 24
POSTGRES_PASSWORD=change_me
OPENSEARCH_PASSWORD=change_me_must_be_strong_8+chars_with_upper_lower_digit
NEO4J_PASSWORD=change_me
RABBITMQ_PASSWORD=change_me
DASHBOARD_PASSWORD=change_me
DASHBOARD_SECRET_KEY=change_me_random_32+_chars

# Audit-log encryption key. REQUIRED — every service exits on startup if this is
# missing or invalid. It MUST be a valid Fernet key (32 url-safe base64 bytes).
# Generate one with EITHER:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   openssl rand -base64 32 | tr '+/' '-_'
AUDIT_ENCRYPTION_KEY=

# ── OPTIONAL — Tor control (leave blank for no control-port auth) ───────────
TOR_CONTROL_PASSWORD=

# ── OPTIONAL — Admin Panel (separation of duties) ──────────────────────────
# If unset, the Admin Panel falls back to DASHBOARD_USERNAME/PASSWORD with a
# startup warning. Set distinct values for real separation between "propose a
# source" (analyst) and "approve a source" (admin).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── OPTIONAL — sensible defaults if omitted ────────────────────────────────
RABBITMQ_USER=dwitp
POSTGRES_USER=dwitp
POSTGRES_DB=dwitp
DASHBOARD_USERNAME=analyst
DASHBOARD_USE_HTTPS=true
CRAWLER_IDENTITY=crawler-01
CIRCUIT_ROTATION_INTERVAL=15
PI_CAMPAIGN_THRESHOLD=5
GRAPH_ANALYTICS_INTERVAL=300

# ── OPTIONAL — Dread forum authentication ──────────────────────────────────
# Credential login is captcha-blocked; use a cookie file instead. Export an
# authenticated session to config/dread_cookies.txt (Netscape format). Leaving
# these blank just means Dread crawling stays at the public/login-walled level.
DREAD_USERNAME=
DREAD_PASSWORD=

# ── OPTIONAL — Telegram collection (INTEL-002, observation-only) ────────────
# Collector stays idle until all three are provided out-of-band (never commit).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_USE_TOR=true

# ── OPTIONAL — Notifications (critical-event alerts) ────────────────────────
# NOTIFIER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
