# DWITP Environment Configuration
# Copy to .env at project root and fill in secrets.
# See .env.example for all available variables.
#
# REQUIRED (no defaults — service will fail to start):
POSTGRES_PASSWORD=change_me_to_a_secure_password
OPENSEARCH_PASSWORD=change_me_to_a_secure_password
NEO4J_PASSWORD=change_me_to_a_secure_password
RABBITMQ_PASSWORD=change_me_to_a_secure_password
TOR_CONTROL_PASSWORD=change_me_to_a_secure_password
DASHBOARD_PASSWORD=change_me_to_a_secure_password
DASHBOARD_SECRET_KEY=change_me_to_a_secure_random_key
#
# OPTIONAL — Admin Panel (source sign-off). If unset, falls back to
# DASHBOARD_USERNAME/DASHBOARD_PASSWORD with a startup warning — set these to
# distinct values for real separation between "propose a source" (main
# dashboard) and "sign off on a source" (Admin Panel):
ADMIN_USERNAME=
ADMIN_PASSWORD=
#
# OPTIONAL — Audit log encryption (if unset, logs are plaintext):
AUDIT_ENCRYPTION_KEY=
#
# OPTIONAL (sensible defaults if omitted):
RABBITMQ_USER=dwitp
POSTGRES_USER=dwitp
POSTGRES_DB=dwitp
DASHBOARD_USE_HTTPS=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
CRAWLER_IDENTITY=crawler-01
CIRCUIT_ROTATION_INTERVAL=15
OLLAMA_MODEL=mistral:7b
PI_CAMPAIGN_THRESHOLD=5
#
# OPTIONAL — Notification (IR-4):
# NOTIFIER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
